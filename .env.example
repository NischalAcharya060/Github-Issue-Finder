# Optional: GitHub personal access token increases rate limit from 60 to 5000 req/hr
# Generate at: https://github.com/settings/tokens (no scopes needed for public data)
NEXT_PUBLIC_GITHUB_TOKEN=

# --- GitHub OAuth App (create at https://github.com/settings/developers) ---
# Homepage URL:           http://localhost:3000
# Authorization callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Auth.js --- (generate AUTH_SECRET with: npx auth secret)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# --- Database (Neon/Supabase Postgres connection string) ---
# DATABASE_URL = pooled connection (runtime); DIRECT_URL = direct (migrations)
DATABASE_URL=
DIRECT_URL=
